---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import SeoHead from '../components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  keywords?: string[];
  imagePath?: string;
  pageType?: 'website' | 'article';
  publishedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath,
  keywords,
  imagePath,
  pageType,
  publishedTime,
  structuredData,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      keywords={keywords}
      imagePath={imagePath}
      pageType={pageType}
      publishedTime={publishedTime}
      structuredData={structuredData}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-shell">
        <a class="brand" href="/">
          <span class="brand__title">{siteConfig.siteName}</span>
          <span class="brand__sub">量化交易与研究博客</span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          {siteConfig.navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main class="container page-shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-shell">
        <div>
          <strong>{siteConfig.siteName}</strong>
          <p>围绕量化策略、交易系统、数据研究与风险管理，持续沉淀可复用的研究框架。</p>
        </div>
        <div class="footer-links">
          <a href="https://www.kuankedao.com">www.kuankedao.com</a>
          <a href="/blog/">最新文章</a>
          <a href="/search/">搜索</a>
          <a href="/blog/categories/">分类</a>
          <a href="/blog/tags/">标签</a>
          <a href="/rss.xml">RSS</a>
          <a href="/about/">关于宽客岛</a>
        </div>
      </div>
    </footer>
  </body>
</html>
