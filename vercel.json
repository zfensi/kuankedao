{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/request.html", "destination": "/contact.html", "permanent": true },
    { "source": "/en/request.html", "destination": "/en/contact.html", "permanent": true },
    { "source": "/zh-tw/request.html", "destination": "/zh-tw/contact.html", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/resources.html", "destination": "/index.html" },
    { "source": "/partners.html", "destination": "/index.html" },
    { "source": "/community.html", "destination": "/index.html" },
    { "source": "/blog.html", "destination": "/index.html" },
    { "source": "/price.html", "destination": "/index.html" },
    { "source": "/link-building-services.html", "destination": "/index.html" },
    { "source": "/about.html", "destination": "/index.html" },
    { "source": "/terms.html", "destination": "/index.html" },
    { "source": "/privacy.html", "destination": "/index.html" },
    { "source": "/Our-Process-Refund.html", "destination": "/index.html" },
    { "source": "/contact.html", "destination": "/index.html" },
    { "source": "/support.html", "destination": "/index.html" },
    { "source": "/resources/(.*).html", "destination": "/index.html" },
    { "source": "/community/(.*).html", "destination": "/index.html" },
    { "source": "/blog/(.*).html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/index.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/resources.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/partners.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/community.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/blog.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/price.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/link-building-services.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/about.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/terms.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/privacy.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/Our-Process-Refund.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/contact.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/support.html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/resources/(.*).html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/community/(.*).html", "destination": "/index.html" },
    { "source": "/(en|zh-tw)/blog/(.*).html", "destination": "/index.html" }
  ]
}
