    { "source": "/Our-Process-Refund.html", "destination": "/index.html" },
    { "source": "/contact.html", "destination": "/index.html" },
    { "source": "/support.html", "destination": "/index.html" },
    { "source": "/resources/(.*).html", "destination": "/index.html" },
    { "source": "/community/(.*).html", "destination": "/index.html" },
