{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/index.html", "destination": "/index.html" },
    { "source": "/resources.html", "destination": "/index.html" },
    { "source": "/partners.html", "destination": "/index.html" },
    { "source": "/community.html", "destination": "/index.html" },
    { "source": "/blog.html", "destination": "/index.html" },
